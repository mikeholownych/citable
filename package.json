    "test:integration": "node --test --test-concurrency=1 --test-reporter=spec 'tests/integration/**/*.test.js'",
    "test:e2e": "node --test --test-concurrency=1 'tests/e2e/**/*.test.js'",
    "build:dist": "node scripts/build-dist.js",
