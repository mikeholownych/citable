{
  "$id": "citable://schemas/field-validation-metrics.schema.json", "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Publishable field-validation metrics", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "version", "provenance", "evaluation_design", "population", "detector_versions", "detector_accuracy", "reviewer_metrics", "execution_metrics", "remediation_metrics", "metric_definitions", "unknown_false_negatives", "false_negative_discovery_limitations", "causal_limitations", "limitations", "metrics_hash"],
  "properties": {
    "schema_version": { "const": 1 }, "corpus_id": { "type": "string" }, "version": { "type": "string" },
    "provenance": { "type": "object", "additionalProperties": false, "required": ["corpus_hash", "corpus_created_at", "collection_started_at", "collection_ended_at"], "properties": { "corpus_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "corpus_created_at": { "type": "string", "format": "date-time" }, "collection_started_at": { "type": "string", "format": "date-time" }, "collection_ended_at": { "type": "string", "format": "date-time" } } },
    "evaluation_design": { "type": "object" }, "population": { "type": "object" },
    "detector_versions": { "type": "object", "additionalProperties": false, "required": ["versions", "mixed_versions", "cases_by_version"], "properties": { "versions": { "type": "array", "items": { "type": "string" } }, "mixed_versions": { "type": "boolean" }, "cases_by_version": { "type": "object" } } },
    "detector_accuracy": { "type": "object" }, "reviewer_metrics": { "type": "object" }, "execution_metrics": { "type": "object" }, "remediation_metrics": { "type": "object" },
    "metric_definitions": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "object", "additionalProperties": false, "required": ["value", "numerator", "denominator", "population", "exclusions", "confidence_limitations"], "properties": { "value": { "type": ["number", "null"] }, "numerator": { "type": ["number", "null"] }, "denominator": { "type": ["number", "null"] }, "population": { "type": "string", "minLength": 1 }, "exclusions": { "type": "array", "items": { "type": "string" } }, "confidence_limitations": { "type": "array", "minItems": 1, "items": { "type": "string" } } } } },
    "unknown_false_negatives": { "type": "object", "additionalProperties": false, "required": ["status", "reason"], "properties": { "status": { "const": "not_quantified" }, "reason": { "type": "string", "minLength": 1 } } },
    "false_negative_discovery_limitations": { "type": "array" }, "causal_limitations": { "type": "array" }, "limitations": { "type": "array" }, "metrics_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
