{
  "$id": "citable://schemas/deployment-receipt.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Publisher-controlled deployment receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "release_id", "manifest_hash", "surface_id", "url", "projection_id", "expected_projection_hash", "observed_projection_hash", "response_hash", "http", "collector", "collected_at", "expires_at", "authority", "verification_status", "limitations", "receipt_hash"],
  "properties": {
    "schema_version": { "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^RECEIPT-[A-F0-9]+$" },
    "release_id": { "type": "string", "pattern": "^RELEASE-v" },
    "manifest_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "surface_id": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "projection_id": { "type": "string", "minLength": 1 },
    "expected_projection_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "observed_projection_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "response_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "http": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "final_url", "redirect_chain", "headers"],
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "final_url": { "type": "string", "format": "uri" },
        "redirect_chain": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "version", "method", "request_identity", "region"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "request_identity": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 }
      }
    },
    "collected_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "authority": { "$ref": "citable://schemas/evidence-authority.schema.json" },
    "verification_status": { "enum": ["verified", "contradictory", "insufficient_evidence", "failed"] },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "receipt_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
