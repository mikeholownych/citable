{
  "$id": "citable://schemas/release-manifest.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_id", "version", "commit", "generated_at", "toolchain", "facts", "projections", "controlled_surfaces", "manifest_hash"],
  "properties": {
    "schema_version": { "const": 1 },
    "release_id": { "type": "string", "pattern": "^RELEASE-v[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "citable"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "citable": { "type": "string", "minLength": 1 }
      }
    },
    "facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detectors", "namespaces", "registries", "providers", "distribution_files_per_provider"],
      "properties": {
        "detectors": { "type": "integer", "minimum": 0 },
        "namespaces": { "type": "integer", "minimum": 0 },
        "registries": { "type": "integer", "minimum": 0 },
        "providers": { "type": "integer", "minimum": 0 },
        "distribution_files_per_provider": { "type": "integer", "minimum": 0 }
      }
    },
    "projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["projection_id", "path", "sha256", "bytes", "authority"],
        "properties": {
          "projection_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 },
          "authority": { "enum": ["control_plane"] }
        }
      }
    },
    "controlled_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_id", "url", "projection_id", "required_for_finalization"],
        "properties": {
          "surface_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "projection_id": { "type": "string", "minLength": 1 },
          "required_for_finalization": { "type": "boolean" }
        }
      }
    },
    "manifest_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
